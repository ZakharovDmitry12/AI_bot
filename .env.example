BOT_TOKEN=telegram_bot_token_here

# Для OpenRouter лучше использовать это имя.
OPENROUTER_API_KEY=openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Необязательно. OpenRouter использует эти заголовки для attribution/rankings.
OPENROUTER_APP_NAME=Telegram AI Bot
OPENROUTER_SITE_URL=

# Сколько последних сообщений хранить после system prompt.
MAX_DIALOG_MESSAGES=10

# Защита от бесконечных tool-calling циклов.
MAX_TOOL_ROUNDS=3

# Голосовой ассистент.
# Можно указать часть имени устройства или индекс из `python -m voice.devices`.
VOICE_INPUT_DEVICE=SoundJoy2
VOICE_OUTPUT_DEVICE=SoundJoy2
VOICE_USER_ID=local-speaker
VOICE_RECORD_SECONDS=8
VOICE_SAMPLE_RATE=16000
VOICE_WAKE_WORD=jarvis
VOICE_WAKE_WORD_ALIASES=jarvis,jarviz,jarviss,jarvez,jervis,jerviz,jarves,jerves,jar vis,jar viz,jar viss,jar vizz,jar ves,jar vez,jar vice,jar vise,jer vis,jer viz,jer viss,jer vizz,j arvis,j ar viz,джарвис,джарвиз,джервис,джар вис,джар виз,жарвис,жарвиз,ярвис
VOICE_WAKE_MODEL_PATH=.venv\vosk\vosk-model-small-ru-0.22
VOICE_WAKE_GAIN=12
VOICE_WAKE_SILENCE_SECONDS=0.8
VOICE_WAKE_MAX_RECORD_SECONDS=4
VOICE_WAKE_STT_INTERVAL_SECONDS=1
VOICE_WAKE_WINDOW_SECONDS=3
VOICE_WAKE_MIN_VOICED_SECONDS=0.1
VOICE_SILENCE_SECONDS=2
VOICE_MAX_RECORD_SECONDS=20
VOICE_PRE_ROLL_SECONDS=0.3
VOICE_MIN_SPEECH_RMS=0.003
VOICE_MAX_SILENCE_THRESHOLD=0.02
VOICE_NOISE_MULTIPLIER=3
VOICE_AUDIO_WARMUP_SECONDS=0.3
VOICE_LOG_LEVEL=INFO

# OpenRouter Speech-to-Text.
OPENROUTER_STT_MODEL=openai/gpt-4o-transcribe
OPENROUTER_STT_FALLBACK_MODEL=openai/whisper-large-v3
OPENROUTER_STT_LANGUAGE=ru

# Piper Text-to-Speech. Укажи реальные пути к piper.exe и ru_RU voice model.
PIPER_EXE=piper
PIPER_MODEL=C:\path\to\ru_RU-irina-medium.onnx
PIPER_CONFIG=C:\path\to\ru_RU-irina-medium.onnx.json
