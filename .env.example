BOT_TOKEN=telegram_bot_token_here

# Для OpenRouter лучше использовать это имя.
OPENROUTER_API_KEY=openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1

# Необязательно. OpenRouter использует эти заголовки для attribution/rankings.
OPENROUTER_APP_NAME=Telegram AI Bot
OPENROUTER_SITE_URL=

# Сколько последних сообщений хранить после system prompt.
MAX_DIALOG_MESSAGES=10

# Защита от бесконечных tool-calling циклов.
MAX_TOOL_ROUNDS=3
